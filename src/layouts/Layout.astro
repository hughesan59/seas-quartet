---
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/playfair-display/wght-italic.css';
import '@fontsource-variable/montserrat';
import '@fontsource/cinzel/400.css';
import '@fontsource/cinzel/500.css';
import '@fontsource/cinzel/600.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import siteData from '../data/site.json';

interface Props {
	title?: string;
	description?: string;
	theme?: 'dark' | 'light';
	showBookingCta?: boolean;
}

const { title, description, theme = 'dark', showBookingCta = true } = Astro.props;
const pageTitle = title
	? `${title} | ${siteData.title}`
	: `${siteData.title} - ${siteData.tagline}`;
const pageDescription = description || siteData.description;
const isLight = theme === 'light';
---

<!doctype html>
<html lang="en" class:list={[isLight && 'theme-light']}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="robots" content="noindex" />

		<meta name="description" content={pageDescription} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<title>{pageTitle}</title>
		<JsonLd />
		<script is:inline>
			document.documentElement.setAttribute('data-js', '');
		</script>
	</head>
	<body
		class:list={[
			'min-h-screen flex flex-col',
			isLight
				? 'bg-background-light text-stone-800'
				: 'bg-background-dark text-stone-300',
		]}>
		<Header isLight={isLight} />
		<div id="page-content" class="flex-grow flex flex-col">
			<slot />
			<Footer showCta={showBookingCta} isLight={isLight} />
		</div>
	</body>
</html>
