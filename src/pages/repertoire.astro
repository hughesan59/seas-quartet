---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const repEntry = await getEntry('repertoire', 'repertoire');
const { heading, subtitle, note, categories } = repEntry.data;
---

<Layout title="Repertoire" description="Browse the Seas Quartet repertoire — from classical masterworks to contemporary favourites for weddings, parties, and corporate events." theme="light">
	<main class="max-w-4xl mx-auto px-6 py-20 text-center">
		<div class="mb-16">
			<p
				class="font-accent text-sm tracking-[0.3em] text-primary mb-4 uppercase">
				{subtitle}
			</p>
			<h1 class="font-display italic text-4xl md:text-6xl text-stone-900 mb-6">
				{heading}
			</h1>
			{note && <p class="font-body tracking-wider text-sm">{note}</p>}
		</div>
		<div class="space-y-20">
			{
				categories.map((category) => (
					<section>
						<h2 class="font-display italic text-2xl md:text-3xl text-primary mb-8">
							{category.title}
						</h2>
						<ul class="flex flex-col border-t border-primary/20 list-none p-0 m-0">
							{category.pieces.map((piece) => (
								<li class="border-b border-primary/20 last:border-b-0 py-4 px-2">
									<p class="text-sm md:text-base tracking-wide">
										<span class="font-semibold">{piece.composer}</span> &middot;{' '}
										{piece.title}
									</p>
								</li>
							))}
						</ul>
					</section>
				))
			}
		</div>
	</main>
	<div
		class="fixed inset-0 pointer-events-none opacity-[0.03] overflow-hidden z-[-1]">
		<svg height="100%" width="100%">
			<filter id="grainy">
				<feTurbulence baseFrequency="0.65" type="fractalNoise"></feTurbulence>
			</filter>
			<rect filter="url(#grainy)" height="100%" width="100%"></rect>
		</svg>
	</div>
</Layout>
